# Fly.io deployment for the remote MCP connector (workflowy-mcp-http).
# Secrets are NOT in this file — set them with `fly secrets set` (see
# docs/REMOTE-CONNECTOR.md). Copy this to `fly.toml` and set your own unique
# `app` name (globally unique across Fly) before deploying. `fly.toml` itself is
# gitignored so a personal deployment name never lands in the repo.

app = "your-workflowy-connector"
primary_region = "lhr"

[build]
  dockerfile = "Dockerfile"

[env]
  PORT = "8080"
  # No persistent volume: the name index lives in memory and rebuilds
  # opportunistically from tool-call walks. WORKFLOWY_INDEX_PATH is left unset
  # (persistence disabled) — see docs/REMOTE-CONNECTOR.md.

[http_service]
  internal_port = 8080
  force_https = true
  auto_stop_machines = "suspend"
  auto_start_machines = true
  min_machines_running = 1

  [[http_service.checks]]
    method = "GET"
    path = "/healthz"
    interval = "30s"
    timeout = "5s"
    grace_period = "10s"

[[vm]]
  size = "shared-cpu-1x"
  memory = "512mb"
