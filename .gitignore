node_modules/
dist/
# Dispatch prompt for the scheduled second-brain workflow — carries personal
# node IDs and Drive paths; never tracked (explicit even though dist/ already
# ignores it, so it stays out even if dist/ artefacts are ever force-added).
dist/daily-second-brain-workflow.dispatch.md
.env
# Personal Fly deployment config (carries the user's unique app name). The
# committed template is fly.toml.example; copy it to fly.toml locally.
/fly.toml
# App-scoped Fly deploy token (least-privilege deploy credential). NEVER
# tracked — it can deploy/manage this one app. Created by scripts/deploy.sh
# on first run; store in a password manager for backup.
.fly.deploy.token
*.fly.token
*.log
.DS_Store
coverage/
target/

# Claude Code skills live in ~/.claude/skills/, not in the repo.
.claude/skills/

# wflow eval suite — behavioural tests for a separate skill, pulled
# in by tooling but not intended to be tracked here.
Evals/

# Ignore root .md files except the canonical entrypoints. Everything else
# (notes, drafts, working docs) belongs in ~/code/secondBrain/, not the repo.
/*.md
!README.md
!BOOTSTRAP.md
!CLAUDE.md

# Local working notes — cross-session todos, eval runs, reliability
# scratchpads. Replaces the previous habit of filing follow-ups as
# Workflowy "system tasks" — keep them on disk, out of the tracked
# tree. New session? Re-read tasks/todo.local.md first.
tasks/
