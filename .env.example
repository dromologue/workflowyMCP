# Workflowy MCP server — environment template. Copy to `.env` for local use.
# `.env` is gitignored; never commit real secrets.

# --- Required ---
WORKFLOWY_API_KEY=

# --- Optional ---
# Disk path for the persistent name index. Unset/empty = in-memory only.
WORKFLOWY_INDEX_PATH=
# Root of the operational secondBrain dir (drafts/session-logs/briefs).
SECONDBRAIN_DIR=
# Default root node for the `review` and `audit_mirrors` tools when the caller
# omits root_id (e.g. your "Distillations" / review-anchor node). No hardcoded
# fallback: if unset, those two tools require an explicit root_id.
WORKFLOWY_REVIEW_ROOT=
