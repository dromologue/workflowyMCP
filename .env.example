# Workflowy MCP server — environment template. Copy to `.env` for local use.
# `.env` is gitignored; never commit real secrets. On Fly.io use `fly secrets
# set` instead of a committed file (see docs/REMOTE-CONNECTOR.md).

# --- Required (all binaries) ---
WORKFLOWY_API_KEY=

# --- Optional (all binaries) ---
# Disk path for the persistent name index. Unset/empty = in-memory only.
WORKFLOWY_INDEX_PATH=
# Root of the operational secondBrain dir (drafts/session-logs/briefs).
SECONDBRAIN_DIR=
# Default root node for the `review` and `audit_mirrors` tools when the caller
# omits root_id (e.g. your "Distillations" / review-anchor node). No hardcoded
# fallback: if unset, those two tools require an explicit root_id.
WORKFLOWY_REVIEW_ROOT=

# --- Remote connector only (workflowy-mcp-http) ---
# Bind address + port for the HTTP listener.
BIND_ADDR=0.0.0.0
PORT=8080

# OAuth resource-server gate. REQUIRED unless MCP_AUTH_DISABLED=1.
# Issuer + JWKS come from your managed provider (Stytch/WorkOS/Auth0/Scalekit).
MCP_OAUTH_ISSUER=
MCP_OAUTH_JWKS_URL=
# Public origin of this connector (no path, no trailing slash). The MCP
# endpoint is <base>/mcp; protected-resource metadata is served at the root.
MCP_PUBLIC_BASE_URL=
# Expected JWT audience. Defaults to <MCP_PUBLIC_BASE_URL>/mcp if unset.
MCP_OAUTH_AUDIENCE=
# Comma-separated allow-lists for the rmcp service (DNS-rebinding defence).
MCP_ALLOWED_HOSTS=
MCP_ALLOWED_ORIGINS=

# LOCAL TESTING ONLY: set to 1 to remove the bearer gate. NEVER in a public
# deployment — the tool surface includes delete_node / bulk_update.
# MCP_AUTH_DISABLED=1
